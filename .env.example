# ==============================================================================
# Currency Tracker Platform - Environment Configuration Example
# ==============================================================================

# ------------------------------------------------------------------------------
# General Settings
# ------------------------------------------------------------------------------
PROJECT_NAME="Currency Tracker Platform"
ENV="development" # Options: development, testing, production
DEBUG=true
API_V1_STR="/api/v1"

# CORS configuration (comma-separated exact origins — no wildcards)
# Local development
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000,https://aero-exchange.vercel.app,https://aero-exchange-git-main.vercel.app"

# ------------------------------------------------------------------------------
# Security & Authentication (JWT)
# ------------------------------------------------------------------------------
# Run 'openssl rand -hex 32' to generate a secure secret key
SECRET_KEY="replace_this_with_a_secure_high_entropy_random_hex_string_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Database Configurations (PostgreSQL)
# ------------------------------------------------------------------------------
# Full connection string (takes precedence over individual components).
# Render provides this automatically via fromDatabase property.
# For Render: DATABASE_URL is auto-populated with sslmode=require
DATABASE_URL=""

# Individual components (used as fallback when DATABASE_URL is not set)
# Note: For Docker services, use 'db' as the POSTGRES_SERVER
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres_secure_password"
POSTGRES_DB="currency_tracker"

# SSL mode for database connections (required for Render, Neon, Supabase, etc.)
# This controls whether SSL is enforced via asyncpg connect_args (NOT via URL param).
# Options: disable, allow, prefer, require, verify-ca, verify-full
DATABASE_SSLMODE="require"

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800

# ------------------------------------------------------------------------------
# Cache Configurations (Redis)
# ------------------------------------------------------------------------------
# Full connection string (takes precedence over individual components).
# Render provides this automatically via fromService property.
# For Render: uses rediss:// (SSL) scheme automatically
REDIS_URL=""

# Individual components (used as fallback when REDIS_URL is not set)
# Note: For Docker services, use 'redis' as the REDIS_HOST
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""
REDIS_MAX_CONNECTIONS=50

# ------------------------------------------------------------------------------
# Exchange Rate API Configuration
# ------------------------------------------------------------------------------
EXCHANGE_RATE_API_KEY="your_api_key_here"

# ------------------------------------------------------------------------------
# Email / SMTP Configuration (example with Gmail)
# ------------------------------------------------------------------------------
# EMAILS_FROM_EMAIL="you@gmail.com"
# EMAILS_FROM_NAME="Currency Tracker"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="you@gmail.com"
# SMTP_PASSWORD="your_gmail_app_password"
# SMTP_SECURE=false

# ------------------------------------------------------------------------------
# Docker and Production Settings
# ------------------------------------------------------------------------------
# Auto-run migrations on startup (true/false)
RUN_MIGRATIONS=true

# Number of uvicorn worker processes in production
UVICORN_WORKERS=4

# Docker registry settings (used in docker-compose.prod.yml)
DOCKER_REGISTRY="ghcr.io"
DOCKER_REPOSITORY="username/currency-tracker"
IMAGE_TAG="latest"

# ------------------------------------------------------------------------------
# Deployment Server Settings (used in GitHub Actions CD)
# ------------------------------------------------------------------------------
# DEPLOY_HOST="your-server-ip"
# DEPLOY_USER="deploy"
# DEPLOY_PORT=22
# DEPLOY_DIR="/opt/currency-tracker"
# DEPLOY_URL="https://your-domain.com"
