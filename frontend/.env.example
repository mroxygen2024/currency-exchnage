# Frontend Environment Variables
# Copy this file to .env and fill in the values

# Backend API base URL (used by Axios client)
# Development:  http://localhost:8000/api/v1
# Production:   https://<your-render-service>.onrender.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Optional: API request timeout in milliseconds (default: 10000)
# VITE_API_TIMEOUT=10000

# Optional: Enable response schema validation (default: true in dev, false in prod)
# VITE_VALIDATE_API_RESPONSES=true

# Optional: Log schema validation errors to console (default: true)
# VITE_LOG_API_VALIDATION_ERRORS=true
